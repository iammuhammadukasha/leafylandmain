# Copy to .env and fill in for local development.
# Matches docker-compose.yml at the repo root (docker compose up -d).

# Postgres (Prisma)
DATABASE_URL="postgresql://leafyland:leafyland@localhost:5432/leafyland?schema=public"

# Redis (session cache, rate limiting, BullMQ — wired in a later slice)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Email verification token signing (stub email sender logs to console)
EMAIL_VERIFICATION_SECRET="change-me-email-verification-secret"
EMAIL_VERIFICATION_EXPIRES_IN="24h"

# App
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# Razorpay (Orders module — FR-ORD-003). Payment order creation is STUBBED
# (no real Razorpay API call, see StubRazorpayGateway); this secret is only
# used for real HMAC-SHA256 webhook signature verification (BR-ORD-01).
RAZORPAY_WEBHOOK_SECRET="dev-razorpay-webhook-secret-change-me"
