// LeafyLand v2 — Prisma schema
// Scope: Identity context (Volume 04 §2) + User context (Volume 04 §3) +
// Vendor context (Volume 04 §4, registration/verification/store-profile +
// minimal vendor_documents) + Product Marketplace context (Volume 04 §5,
// categories/products/variants vertical slice) + Orders context (Volume 04
// §6, cart/checkout/webhook-payment/vendor-fulfillment vertical slice — see
// that section's header comment below for exact scope/deferrals).
//
// Vendor context slice covers FR-VND-001 (register), FR-VND-002 (admin
// verify), FR-VND-003 (store profile update via PATCH /vendors/me),
// GET /vendors/me, and a minimal FR-VND-008 (vendor_documents: create/list/
// admin-approve — no reject variant, no file upload, no expiry reminders).
// vendor_staff_invitations and vendor_wallet_ledger (Volume 04 §4) remain
// deliberately NOT modeled — they back FR-VND-004/006 which are out of
// scope for this slice.
//
// Product Marketplace context slice covers FR-PRD-001 (categories only —
// brands deferred), FR-PRD-002 (products + variants), FR-VND-005
// (vendor-side product management, including the BR-PRD-01/BR-VND-02
// cross-context organic-claim rule), and FR-PRD-004 (reviews & Q&A — see
// that section's header comment below for scope/deviations). See final
// report for the full remaining deferred list (offers/coupons, search,
// recommendations, compare, brands CRUD).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  active
  suspended
  deleted
}

enum AuthProvider {
  password
  google
  otp
}

enum RoleName {
  shopper
  vendor_owner
  vendor_staff
  admin
  super_admin
}

enum AddressType {
  billing
  shipping
}

enum VendorStatus {
  pending
  verified
  rejected
  revoked
}

enum VendorDocumentType {
  business_registration
  organic_certificate
  other
}

enum VendorDocumentReviewStatus {
  pending
  approved
  rejected
}

enum ProductStatus {
  draft
  active
  delisted
}

enum CartStatus {
  active
  converted
  abandoned
}

// Volume 02 §6.2: pending_payment, paid, shipped, delivered, cancelled,
// refunded. This slice only drives pending_payment -> paid (checkout +
// webhook). shipped/delivered/cancelled/refunded exist as values so the
// column never needs a migration to add them later, but no endpoint in
// this slice transitions an order into them (FR-ORD-004/005/006 deferred).
enum OrderStatus {
  pending_payment
  paid
  shipped
  delivered
  cancelled
  refunded
}

// Volume 04 §6 order_lines.status. `fulfilled` is now reachable via
// FR-ORD-006 (DeliverShipmentUseCase transitions a vendor's order lines to
// fulfilled when their shipment reaches `delivered`). `returned`/`refunded`
// remain deferred along with the `returns` table (FR-ORD-005).
enum OrderLineStatus {
  pending
  fulfilled
  returned
  refunded
}

// Volume 04 §6 shipments.status (FR-ORD-006).
enum ShipmentStatus {
  pending
  shipped
  delivered
}

// ---------------------------------------------------------------------------
// Identity context (Volume 04 §2)
// ---------------------------------------------------------------------------

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.Citext
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz
  phone           String?    @unique
  passwordHash    String?    @map("password_hash")
  status          UserStatus @default(active)
  mfaEnabled      Boolean    @default(false) @map("mfa_enabled")

  // Standard columns (Constitution §7)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  authIdentities AuthIdentity[]
  sessions       Session[]
  userRoles      UserRole[]
  mfaSecret      MfaSecret?
  profile        UserProfile?
  addresses      Address[]
  auditLogs      AuditLog[]     @relation("AuditLogActor")
  ownedVendors   Vendor[]
  carts          Cart[]
  orders         Order[]

  @@map("users")
}

// no soft delete: pure login-method linkage record (Volume 04 §2)
model AuthIdentity {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  provider       AuthProvider
  providerUserId String?      @map("provider_user_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  version   Int      @default(1)

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_identities")
}

// no soft delete, seed data (Volume 04 §2)
model Role {
  id   String   @id @default(uuid()) @db.Uuid
  name RoleName @unique

  userRoles UserRole[]

  @@map("roles")
}

// no soft delete (Volume 04 §2)
// vendorId now FKs to Vendor (added below) now that the Vendor context
// exists — scopes vendor_owner/vendor_staff rows to one vendor, per
// FR-ID-006. Global roles (shopper, admin, super_admin) leave vendorId
// null.
//
// DEVIATION from Volume 04 §2: the doc specifies
// `PRIMARY KEY(user_id, role_id, vendor_id)` with vendor_id nullable.
// Standard SQL (and Prisma) require every column in a composite primary
// key to be NOT NULL, so a nullable column cannot participate in a PK —
// this is a genuine inconsistency in the source doc, not implementer
// preference. Fixed here with a surrogate `id` PK plus a unique
// constraint using `COALESCE`-free nullable-safe indexing: Postgres
// treats NULLs as distinct in unique indexes, which reproduces the
// intended "one row per (user, role, vendor-or-global)" semantics.
model UserRole {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  roleId   String  @map("role_id") @db.Uuid
  vendorId String? @map("vendor_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id])
  role   Role    @relation(fields: [roleId], references: [id])
  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@unique([userId, roleId, vendorId])
  @@index([userId])
  @@index([roleId])
  @@index([vendorId])
  @@map("user_roles")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceLabel      String?   @map("device_label")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  familyId         String    @map("family_id") @db.Uuid
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([familyId])
  @@map("sessions")
}

// no soft delete (Volume 04 §2)
model MfaSecret {
  id                  String @id @default(uuid()) @db.Uuid
  userId              String @unique @map("user_id") @db.Uuid
  totpSecretEncrypted String @map("totp_secret_encrypted")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("mfa_secrets")
}

// append-only, no update/delete (Volume 04 §2)
model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  diff        Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation("AuditLogActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// User context (Volume 04 §3) — profile + addresses only for this slice.
// wishlists / notification_preferences deferred: they FK into products.id
// (Product Marketplace, not built yet) or add no architectural proof value
// for this vertical slice; skipped per task scope, not per doc omission.
// ---------------------------------------------------------------------------

model UserProfile {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  fullName        String?   @map("full_name")
  avatarUrl       String?   @map("avatar_url")
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model Address {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  type       AddressType
  isDefault  Boolean     @default(false) @map("is_default")
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String      @map("postal_code")
  country    String

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  user              User    @relation(fields: [userId], references: [id])
  shippingForOrders Order[] @relation("OrderShippingAddress")
  billingForOrders  Order[] @relation("OrderBillingAddress")

  @@index([userId])
  @@map("addresses")
}

// ---------------------------------------------------------------------------
// Vendor context (Volume 04 §4) — registration/verification/store-profile
// vertical slice only (FR-VND-001/002/003, GET /vendors/me). Documents,
// staff invitations, and wallet ledger tables are deliberately NOT modeled
// — see file header note.
// ---------------------------------------------------------------------------

model Vendor {
  id                String       @id @default(uuid()) @db.Uuid
  ownerUserId       String       @map("owner_user_id") @db.Uuid
  businessName      String       @map("business_name")
  description       String?
  logoUrl           String?      @map("logo_url")
  bannerUrl         String?      @map("banner_url")
  status            VendorStatus @default(pending)
  // Basis points; nullable = "no vendor-specific override, use the
  // category default" (Volume 02 §4 FR-VND-006 — category-based default
  // with per-vendor override). Category defaults aren't modeled yet
  // (Product Marketplace context, out of scope), so this column exists per
  // the ERD but is left null by this slice's use cases; commission
  // computation itself is FR-VND-006, explicitly deferred.
  commissionRateBps Int?         @map("commission_rate_bps")
  verifiedAt        DateTime?    @map("verified_at") @db.Timestamptz
  rejectedReason    String?      @map("rejected_reason")

  // Standard columns (Constitution §7)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  owner     User             @relation(fields: [ownerUserId], references: [id])
  userRoles UserRole[]
  documents VendorDocument[]
  products  Product[]

  @@index([ownerUserId])
  @@map("vendors")
}

// FR-VND-008 (minimal slice) — vendor business/certification documents.
// Added alongside Product Marketplace because BR-PRD-01/BR-VND-02 (organic
// claim requires an approved organic_certificate document) is the cross-
// context rule this slice exists to prove; file upload/S3 integration is
// out of scope — fileUrl just accepts a string URL (see Volume 07 §4.1
// note re-read for this slice).
model VendorDocument {
  id           String                     @id @default(uuid()) @db.Uuid
  vendorId     String                     @map("vendor_id") @db.Uuid
  type         VendorDocumentType
  fileUrl      String                     @map("file_url")
  reviewStatus VendorDocumentReviewStatus @default(pending) @map("review_status")
  expiresAt    DateTime?                  @map("expires_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  vendor   Vendor    @relation(fields: [vendorId], references: [id])
  products Product[]

  @@index([vendorId])
  @@map("vendor_documents")
}

// ---------------------------------------------------------------------------
// Product Marketplace context (Volume 04 §5) — categories/products/variants
// vertical slice only (FR-PRD-001/002, FR-VND-005). `brands` table is
// deliberately NOT modeled this slice — brandId kept nullable on Product
// with no FK, so brand CRUD can be added later without a data migration;
// offers/coupons/reviews are out of scope (see final report for the full
// deferred list).
// ---------------------------------------------------------------------------

// Hierarchical categories, max depth 3 enforced in the application layer
// (not the DB — Volume 04 §5 note), self-referential tree.
model Category {
  id         String  @id @default(uuid()) @db.Uuid
  parentId   String? @map("parent_id") @db.Uuid
  name       String
  slug       String  @unique
  taxRateBps Int     @map("tax_rate_bps")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id                    String        @id @default(uuid()) @db.Uuid
  vendorId              String        @map("vendor_id") @db.Uuid
  categoryId            String        @map("category_id") @db.Uuid
  // brands table intentionally not modeled this slice (see file header) —
  // brandId kept as a bare nullable column, no FK, so no brand row can be
  // referenced yet. Every product is created with brandId = null.
  brandId               String?       @map("brand_id") @db.Uuid
  title                 String
  description           String?
  isOrganicClaim        Boolean       @default(false) @map("is_organic_claim")
  // Required when isOrganicClaim = true; enforced in the application layer
  // per BR-PRD-01 (ties to BR-VND-02), not a DB CHECK constraint.
  organicCertDocumentId String?       @map("organic_cert_document_id") @db.Uuid
  status                ProductStatus @default(draft)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  vendor              Vendor           @relation(fields: [vendorId], references: [id])
  category            Category         @relation(fields: [categoryId], references: [id])
  organicCertDocument VendorDocument?  @relation(fields: [organicCertDocumentId], references: [id])
  variants            ProductVariant[]
  reviews             Review[]
  questions           Question[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([organicCertDocumentId])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id                String @id @default(uuid()) @db.Uuid
  productId         String @map("product_id") @db.Uuid
  sku               String @unique
  attributes        Json
  priceMinor        BigInt @map("price_minor")
  stockQuantity     Int    @map("stock_quantity")
  lowStockThreshold Int    @map("low_stock_threshold")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_variants")
}

// FR-PRD-004 (Volume 04 §5 `reviews` table). `orderLineId` is unique — one
// review per purchased order line (proves verified-buyer-only reviews, BRS
// §7 rule 4). No FK constraint to `order_lines.id` at the Prisma level:
// order_lines is an Orders-context table and Volume 04 §7 allows DB-level
// FKs across context table groups for referential integrity, but Prisma
// relations require both sides to be modeled in the same schema/client to
// declare a `@relation` — since this is one physical Postgres schema, a raw
// FK is fine at the SQL level, however keeping Review's read of order-line
// facts behind a dedicated cross-context port (OrderLineLookupRepository,
// Product's own domain layer, mirroring VendorLookupRepository) means the
// *application* code never joins across the boundary even though the
// physical FK constraint itself still exists for integrity — added via a
// raw index+unique constraint below rather than a Prisma `@relation` field,
// so Product's Prisma model surface doesn't declare a compile-time
// dependency on the Order/OrderLine models the way a `@relation` would.
model Review {
  id          String @id @default(uuid()) @db.Uuid
  productId   String @map("product_id") @db.Uuid
  userId      String @map("user_id") @db.Uuid
  orderLineId String @unique @map("order_line_id") @db.Uuid
  rating      Int
  body        String

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

// FR-PRD-004 Q&A. NOT specified in Volume 04 §5's ERD (only `reviews` is
// detailed there) — this is a pragmatic, minimal design filled in for this
// slice per the task brief: `Question` (product + asking user + body) and
// `Answer` (question + answering vendor user + body), both with the
// standard Constitution §7 columns. Any authenticated user may ask; only
// the owning vendor's owner/staff may answer (enforced in the application
// layer via the same UserRolesRepository-style DB-backed check Vendor/
// Product already use elsewhere — see AnswerQuestionUseCase).
model Question {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid
  body      String

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  product Product  @relation(fields: [productId], references: [id])
  answers Answer[]

  @@index([productId])
  @@index([userId])
  @@map("questions")
}

model Answer {
  id         String @id @default(uuid()) @db.Uuid
  questionId String @map("question_id") @db.Uuid
  answeredBy String @map("answered_by") @db.Uuid
  body       String

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  question Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
  @@map("answers")
}

// ---------------------------------------------------------------------------
// Orders context (Volume 04 §6) — cart + checkout + webhook-verified payment
// + vendor order fulfillment vertical slice (FR-ORD-001/002/003/006,
// BR-ORD-01). Scope reductions vs the full doc, all deliberate (task
// instruction, not doc omission):
//
//  - Guest cart (nullable carts.user_id, cart merge-on-login) is NOT
//    modeled — `Cart.userId` is required (Auth-only cart per this slice).
//  - `invoices`, `returns` tables are NOT modeled — defers FR-ORD-004
//    (invoices) and FR-ORD-005 (returns/refunds). `shipments` IS now
//    modeled (FR-ORD-006 — see the Shipment model below).
//  - Coupons/offers do not exist yet (Product Marketplace slice didn't
//    model them either), so `orders` has no couponCode/discount columns —
//    not a doc omission, coupons simply aren't buildable yet.
//  - Taxes: category `taxRateBps` flat GST-style calc only, no
//    CGST/SGST/IGST state-based splitting (FR-ORD-007 scope-reduced).
//
// `cart_lines` is explicitly marked "no soft delete" in Volume 04 §6 —
// followed literally below (no deletedAt/createdBy/updatedBy/version).
// ---------------------------------------------------------------------------

model Cart {
  id     String     @id @default(uuid()) @db.Uuid
  userId String     @map("user_id") @db.Uuid
  status CartStatus @default(active)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  user  User       @relation(fields: [userId], references: [id])
  lines CartLine[]

  @@index([userId])
  @@map("carts")
}

// no soft delete (Volume 04 §6 explicit note)
model CartLine {
  id               String @id @default(uuid()) @db.Uuid
  cartId           String @map("cart_id") @db.Uuid
  productVariantId String @map("product_variant_id") @db.Uuid
  quantity         Int

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  cart Cart @relation(fields: [cartId], references: [id])

  @@unique([cartId, productVariantId])
  @@index([cartId])
  @@map("cart_lines")
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  shippingAddressId String      @map("shipping_address_id") @db.Uuid
  billingAddressId  String      @map("billing_address_id") @db.Uuid
  status            OrderStatus @default(pending_payment)
  subtotalMinor     BigInt      @map("subtotal_minor")
  taxMinor          BigInt      @map("tax_minor")
  shippingMinor     BigInt      @map("shipping_minor")
  totalMinor        BigInt      @map("total_minor")
  razorpayOrderId   String?     @map("razorpay_order_id")
  razorpayPaymentId String?     @map("razorpay_payment_id")
  paidAt            DateTime?   @map("paid_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  user            User        @relation(fields: [userId], references: [id])
  shippingAddress Address     @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address     @relation("OrderBillingAddress", fields: [billingAddressId], references: [id])
  lines           OrderLine[]
  shipments       Shipment[]

  @@index([userId])
  @@index([razorpayOrderId])
  @@map("orders")
}

model OrderLine {
  id                    String          @id @default(uuid()) @db.Uuid
  orderId               String          @map("order_id") @db.Uuid
  productVariantId      String          @map("product_variant_id") @db.Uuid
  vendorId              String          @map("vendor_id") @db.Uuid
  quantity              Int
  unitPriceMinor        BigInt          @map("unit_price_minor")
  taxMinor              BigInt          @map("tax_minor")
  commissionBpsSnapshot Int?            @map("commission_bps_snapshot")
  status                OrderLineStatus @default(pending)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([vendorId])
  @@index([productVariantId])
  @@map("order_lines")
}

// FR-ORD-006 (Volume 04 §6 `shipments` table) — vendor order fulfillment.
// "One shipment per vendor per order" per the ERD note: a multi-vendor
// order has one Shipment row per distinct vendorId among its order_lines,
// covering every line that vendor contributed to that order (grouping
// decision documented in ShipOrderLineUseCase's doc comment). No FK to
// OrderLine (a shipment covers a set of lines, not one line) — orderId +
// vendorId is the grouping key, enforced unique below.
model Shipment {
  id             String         @id @default(uuid()) @db.Uuid
  orderId        String         @map("order_id") @db.Uuid
  vendorId       String         @map("vendor_id") @db.Uuid
  carrier        String?
  trackingNumber String?        @map("tracking_number")
  status         ShipmentStatus @default(pending)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  order Order @relation(fields: [orderId], references: [id])

  @@unique([orderId, vendorId])
  @@index([orderId])
  @@index([vendorId])
  @@map("shipments")
}
