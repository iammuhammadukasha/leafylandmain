// LeafyLand v2 — Prisma schema
// Scope: Identity context (Volume 04 §2) + User context (Volume 04 §3) +
// Vendor context (Volume 04 §4, registration/verification/store-profile +
// minimal vendor_documents) + Product Marketplace context (Volume 04 §5,
// categories/products/variants vertical slice). Orders context is NOT
// modeled here yet — wishlists.product_id etc. will be added when Orders
// is scaffolded, per Constitution §11.6 (no speculative abstraction).
//
// Vendor context slice covers FR-VND-001 (register), FR-VND-002 (admin
// verify), FR-VND-003 (store profile update via PATCH /vendors/me),
// GET /vendors/me, and a minimal FR-VND-008 (vendor_documents: create/list/
// admin-approve — no reject variant, no file upload, no expiry reminders).
// vendor_staff_invitations and vendor_wallet_ledger (Volume 04 §4) remain
// deliberately NOT modeled — they back FR-VND-004/006 which are out of
// scope for this slice.
//
// Product Marketplace context slice covers FR-PRD-001 (categories only —
// brands deferred), FR-PRD-002 (products + variants), and FR-VND-005
// (vendor-side product management), including the BR-PRD-01/BR-VND-02
// cross-context organic-claim rule. See final report for the full deferred
// list (offers/coupons, reviews/questions, search, recommendations,
// compare, brands CRUD).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  active
  suspended
  deleted
}

enum AuthProvider {
  password
  google
  otp
}

enum RoleName {
  shopper
  vendor_owner
  vendor_staff
  admin
  super_admin
}

enum AddressType {
  billing
  shipping
}

enum VendorStatus {
  pending
  verified
  rejected
  revoked
}

enum VendorDocumentType {
  business_registration
  organic_certificate
  other
}

enum VendorDocumentReviewStatus {
  pending
  approved
  rejected
}

enum ProductStatus {
  draft
  active
  delisted
}

// ---------------------------------------------------------------------------
// Identity context (Volume 04 §2)
// ---------------------------------------------------------------------------

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.Citext
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz
  phone           String?    @unique
  passwordHash    String?    @map("password_hash")
  status          UserStatus @default(active)
  mfaEnabled      Boolean    @default(false) @map("mfa_enabled")

  // Standard columns (Constitution §7)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  authIdentities AuthIdentity[]
  sessions       Session[]
  userRoles      UserRole[]
  mfaSecret      MfaSecret?
  profile        UserProfile?
  addresses      Address[]
  auditLogs      AuditLog[]     @relation("AuditLogActor")
  ownedVendors   Vendor[]

  @@map("users")
}

// no soft delete: pure login-method linkage record (Volume 04 §2)
model AuthIdentity {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  provider       AuthProvider
  providerUserId String?      @map("provider_user_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  version   Int      @default(1)

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_identities")
}

// no soft delete, seed data (Volume 04 §2)
model Role {
  id   String   @id @default(uuid()) @db.Uuid
  name RoleName @unique

  userRoles UserRole[]

  @@map("roles")
}

// no soft delete (Volume 04 §2)
// vendorId now FKs to Vendor (added below) now that the Vendor context
// exists — scopes vendor_owner/vendor_staff rows to one vendor, per
// FR-ID-006. Global roles (shopper, admin, super_admin) leave vendorId
// null.
//
// DEVIATION from Volume 04 §2: the doc specifies
// `PRIMARY KEY(user_id, role_id, vendor_id)` with vendor_id nullable.
// Standard SQL (and Prisma) require every column in a composite primary
// key to be NOT NULL, so a nullable column cannot participate in a PK —
// this is a genuine inconsistency in the source doc, not implementer
// preference. Fixed here with a surrogate `id` PK plus a unique
// constraint using `COALESCE`-free nullable-safe indexing: Postgres
// treats NULLs as distinct in unique indexes, which reproduces the
// intended "one row per (user, role, vendor-or-global)" semantics.
model UserRole {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  roleId   String  @map("role_id") @db.Uuid
  vendorId String? @map("vendor_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id])
  role   Role    @relation(fields: [roleId], references: [id])
  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@unique([userId, roleId, vendorId])
  @@index([userId])
  @@index([roleId])
  @@index([vendorId])
  @@map("user_roles")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceLabel      String?   @map("device_label")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  familyId         String    @map("family_id") @db.Uuid
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([familyId])
  @@map("sessions")
}

// no soft delete (Volume 04 §2)
model MfaSecret {
  id                  String @id @default(uuid()) @db.Uuid
  userId              String @unique @map("user_id") @db.Uuid
  totpSecretEncrypted String @map("totp_secret_encrypted")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("mfa_secrets")
}

// append-only, no update/delete (Volume 04 §2)
model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  diff        Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation("AuditLogActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// User context (Volume 04 §3) — profile + addresses only for this slice.
// wishlists / notification_preferences deferred: they FK into products.id
// (Product Marketplace, not built yet) or add no architectural proof value
// for this vertical slice; skipped per task scope, not per doc omission.
// ---------------------------------------------------------------------------

model UserProfile {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  fullName        String?   @map("full_name")
  avatarUrl       String?   @map("avatar_url")
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model Address {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  type       AddressType
  isDefault  Boolean     @default(false) @map("is_default")
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String      @map("postal_code")
  country    String

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("addresses")
}

// ---------------------------------------------------------------------------
// Vendor context (Volume 04 §4) — registration/verification/store-profile
// vertical slice only (FR-VND-001/002/003, GET /vendors/me). Documents,
// staff invitations, and wallet ledger tables are deliberately NOT modeled
// — see file header note.
// ---------------------------------------------------------------------------

model Vendor {
  id                String       @id @default(uuid()) @db.Uuid
  ownerUserId       String       @map("owner_user_id") @db.Uuid
  businessName      String       @map("business_name")
  description       String?
  logoUrl           String?      @map("logo_url")
  bannerUrl         String?      @map("banner_url")
  status            VendorStatus @default(pending)
  // Basis points; nullable = "no vendor-specific override, use the
  // category default" (Volume 02 §4 FR-VND-006 — category-based default
  // with per-vendor override). Category defaults aren't modeled yet
  // (Product Marketplace context, out of scope), so this column exists per
  // the ERD but is left null by this slice's use cases; commission
  // computation itself is FR-VND-006, explicitly deferred.
  commissionRateBps Int?         @map("commission_rate_bps")
  verifiedAt        DateTime?    @map("verified_at") @db.Timestamptz
  rejectedReason    String?      @map("rejected_reason")

  // Standard columns (Constitution §7)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  owner     User             @relation(fields: [ownerUserId], references: [id])
  userRoles UserRole[]
  documents VendorDocument[]
  products  Product[]

  @@index([ownerUserId])
  @@map("vendors")
}

// FR-VND-008 (minimal slice) — vendor business/certification documents.
// Added alongside Product Marketplace because BR-PRD-01/BR-VND-02 (organic
// claim requires an approved organic_certificate document) is the cross-
// context rule this slice exists to prove; file upload/S3 integration is
// out of scope — fileUrl just accepts a string URL (see Volume 07 §4.1
// note re-read for this slice).
model VendorDocument {
  id           String                     @id @default(uuid()) @db.Uuid
  vendorId     String                     @map("vendor_id") @db.Uuid
  type         VendorDocumentType
  fileUrl      String                     @map("file_url")
  reviewStatus VendorDocumentReviewStatus @default(pending) @map("review_status")
  expiresAt    DateTime?                  @map("expires_at") @db.Timestamptz

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  vendor   Vendor    @relation(fields: [vendorId], references: [id])
  products Product[]

  @@index([vendorId])
  @@map("vendor_documents")
}

// ---------------------------------------------------------------------------
// Product Marketplace context (Volume 04 §5) — categories/products/variants
// vertical slice only (FR-PRD-001/002, FR-VND-005). `brands` table is
// deliberately NOT modeled this slice — brandId kept nullable on Product
// with no FK, so brand CRUD can be added later without a data migration;
// offers/coupons/reviews are out of scope (see final report for the full
// deferred list).
// ---------------------------------------------------------------------------

// Hierarchical categories, max depth 3 enforced in the application layer
// (not the DB — Volume 04 §5 note), self-referential tree.
model Category {
  id         String  @id @default(uuid()) @db.Uuid
  parentId   String? @map("parent_id") @db.Uuid
  name       String
  slug       String  @unique
  taxRateBps Int     @map("tax_rate_bps")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id                    String        @id @default(uuid()) @db.Uuid
  vendorId              String        @map("vendor_id") @db.Uuid
  categoryId            String        @map("category_id") @db.Uuid
  // brands table intentionally not modeled this slice (see file header) —
  // brandId kept as a bare nullable column, no FK, so no brand row can be
  // referenced yet. Every product is created with brandId = null.
  brandId               String?       @map("brand_id") @db.Uuid
  title                 String
  description           String?
  isOrganicClaim        Boolean       @default(false) @map("is_organic_claim")
  // Required when isOrganicClaim = true; enforced in the application layer
  // per BR-PRD-01 (ties to BR-VND-02), not a DB CHECK constraint.
  organicCertDocumentId String?       @map("organic_cert_document_id") @db.Uuid
  status                ProductStatus @default(draft)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  vendor              Vendor           @relation(fields: [vendorId], references: [id])
  category            Category         @relation(fields: [categoryId], references: [id])
  organicCertDocument VendorDocument?  @relation(fields: [organicCertDocumentId], references: [id])
  variants            ProductVariant[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([organicCertDocumentId])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id                String @id @default(uuid()) @db.Uuid
  productId         String @map("product_id") @db.Uuid
  sku               String @unique
  attributes        Json
  priceMinor        BigInt @map("price_minor")
  stockQuantity     Int    @map("stock_quantity")
  lowStockThreshold Int    @map("low_stock_threshold")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  version   Int       @default(1)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_variants")
}
